# Keep simulation choices in JSON run plans (`sim_actors.json` or GUI plans).
# Keep secrets, credentials, deployment URLs, and deployment path overrides here.

# ── Simulator auth/cache secrets ────────────────────────────────────────────
# Optional cached user auth. The simulator can refresh these after OTP login.
USER_LASTMILE_TOKEN=
USER_ID=
STORE_LASTMILE_TOKEN=

# Test-user password is a credential. Names/email live in the plan.
SIM_NEW_USER_PASSWORD=Password123!

# ── Stripe / payment secrets ────────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── SMTP email notification secrets (required when email notifications enabled) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_MODE=starttls

# ── Base URLs ────────────────────────────────────────────────────────────────
LASTMILE_BASE_URL=https://lastmile.fainzy.tech
FAINZY_BASE_URL=https://fainzy.tech

# ── Web GUI / deployment ─────────────────────────────────────────────────────
SIM_ENV=development
JWT_SECRET_KEY=dev-only-change-me
SIM_AUTH_DISABLED=false
POSTGRES_PASSWORD=simulator123
DATABASE_URL=
SIMULATOR_SESSION_COOKIE_NAME=simulator_session
SIMULATOR_SESSION_MAX_AGE_SECONDS=604800
SIMULATOR_SESSION_COOKIE_SECURE=false
SIMULATOR_SESSION_COOKIE_SAMESITE=lax

# Optional local path overrides. Docker Compose already supplies these.
SIMULATOR_WORKDIR=
SIMULATOR_PROJECT_DIR=
RUN_DB_PATH=
RUN_LOG_DIR=
SIM_GUI_PLANS_DIR=

# Optional websocket gate behavior override (default is false when omitted).
SIM_ENFORCE_WEBSOCKET_GATES=false

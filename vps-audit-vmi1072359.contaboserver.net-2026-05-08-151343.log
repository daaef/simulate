--- /etc/nginx/sites-enabled/fainzy.conf ---
upstream daphne {
	server 0.0.0.0:8003;
}

upstream ros_bridge_daphne {
	server 0.0.0.0:8085;
}

server {
	listen 443 ssl http2;
	listen [::]:443;
	server_name www.fainzy.tech fainzy.tech;

	ssl_certificate /etc/ssl/certs/fainzy.tech.pem;
	ssl_certificate_key /etc/ssl/private/fainzy.tech.key;

	location /static/ {
		alias ~/rds_backend/fainzytech/staticfiles/;
		include proxy_params;
		proxy_pass http://localhost:8000;
	}

	location /media/ {
		alias ~/rds_backend/fainzytech/media/;
		include proxy_params;
		proxy_pass http://localhost:8000;
	}

	location = /favicon.ico { access_log off; log_not_found off; }

	location / {
		proxy_pass http://localhost:8000;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection 'upgrade';
		proxy_set_header Host $host;
		proxy_cache_bypass $http_upgrade;
		fastcgi_connect_timeout 90s;
		fastcgi_send_timeout 90s;
		fastcgi_read_timeout 90s;
		proxy_read_timeout 90s;
	}

	# location /v1/site/ {
	# 	proxy_pass https://localhost:8004;
	# 	proxy_http_version 1.1;
	# 	proxy_set_header Upgrade $http_upgrade;
	# 	proxy_set_header Connection 'upgrade';
	# 	proxy_set_header Host $host;
	# 	proxy_cache_bypass $http_upgrade;
	# }

	location /ws/ {
	alias ~/rds_backend/;
		proxy_pass http://localhost:8001;
	}

	client_max_body_size 30M;
}

server {
	listen 443 ssl http2;
	listen [::]:443;
	server_name lastmile.fainzy.tech www.lastmile.fainzy.tech;
	
	ssl_certificate /etc/ssl/certs/fainzy.tech.pem;
	ssl_certificate_key /etc/ssl/private/fainzy.tech.key;

	location /static/ {
		alias ~/lastmile_backend/staticfiles/;
		include proxy_params;
		proxy_pass http://localhost:8002;
	}

	location /media/ {
		alias ~/lastmile_backend/media/;
		access_log off;
	}

	location = /favicon.ico { access_log off; log_not_found off; }

	location / {
		alias ~/lastmile_backend/;
		proxy_pass http://localhost:8002;
		proxy_set_header Host $host;
		proxy_cache_bypass $http_upgrade;
	}

	location /ws/ {
		alias ~/lastmile_backend/;
		proxy_pass https://daphne;
		proxy_http_version 1.1;
		proxy_redirect off;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
		proxy_read_timeout 86400;
	}
}

server {
	listen 443 ssl http2;
	listen [::]:443;
	server_name rosbridge.fainzy.tech www.rosbridge.fainzy.tech;
				
	ssl_certificate /etc/ssl/certs/fainzy.tech.pem;
	ssl_certificate_key /etc/ssl/private/fainzy.tech.key;

	location /static/ {
		alias ~/ros_bridge/fainzytech/staticfiles/;
		include proxy_params;
		proxy_pass http://localhost:8020;
	}

	location /media/ {
		alias ~/ros_bridge/fainzytech/media/;
		include proxy_params;
		proxy_pass http://localhost:8020;
	}

	location = /favicon.ico { access_log off; log_not_found off; }

	location / {
		proxy_pass http://localhost:8020;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection 'upgrade';
		proxy_set_header Host $host;
		proxy_cache_bypass $http_upgrade;
	}

	location /ws/ {
		alias ~/ros_bridge/;
		proxy_pass https://ros_bridge_daphne;
		proxy_http_version 1.1;
		proxy_redirect off;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
		proxy_read_timeout 86400;
	}

	client_max_body_size 5G;
}


--- /etc/nginx/sites-enabled/netbird.conf ---
server {
    listen 80;
    server_name remote-monitoring.fainzy.ai;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name remote-monitoring.fainzy.ai;

    ssl_certificate /etc/letsencrypt/live/remote-monitoring.fainzy.ai/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/remote-monitoring.fainzy.ai/privkey.pem;

    access_log /var/log/nginx/netbird.access.log;
    error_log /var/log/nginx/netbird.error.log;

    # Defaults for Websockets & gRPC
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # --- Routes from Installer ---

    # 1. Relay Service
    location /relay {
        proxy_pass http://127.0.0.1:8084;
    }

    # 2. Signal WebSocket
    location /ws-proxy/signal {
        proxy_pass http://127.0.0.1:8083;
    }

    # 3. Signal gRPC
    location /signalexchange.SignalExchange/ {
        grpc_pass grpc://127.0.0.1:10000;
        grpc_read_timeout 1d;
        grpc_send_timeout 1d;
        grpc_set_header Host $host;
        grpc_set_header X-Real-IP $remote_addr;
        grpc_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 4. Management API
    location /api {
        proxy_pass http://127.0.0.1:8081;
    }

    # 5. Management WebSocket
    location /ws-proxy/management {
        proxy_pass http://127.0.0.1:8081;
    }

    # 6. Management gRPC
    location /management.ManagementService/ {
        grpc_pass grpc://127.0.0.1:8081;
        grpc_read_timeout 1d;
        grpc_send_timeout 1d;
        grpc_set_header Host $host;
        grpc_set_header X-Real-IP $remote_addr;
        grpc_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 7. Embedded Identity Provider (OAuth)
    location /oauth2 {
        proxy_pass http://127.0.0.1:8081;
    }

    # 8. Dashboard (Catch-all)
    location / {
        proxy_pass http://127.0.0.1:8080;
    }
}


# Simulator production environment template.
# Copy to .env.prod on the deployment host and set real secrets.
# Do not commit .env.prod.

# --- Host exposure (safe defaults) ---
SIMULATOR_HOST_BIND=127.0.0.1
SIMULATOR_HOST_PORT=8090

# --- Core environment ---
SIM_ENV=production
SIM_AUTH_DISABLED=false

# --- Database ---
POSTGRES_DB=simulator
POSTGRES_USER=simulator
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://simulator:change-me@postgres:5432/simulator

# --- Auth/session ---
JWT_SECRET_KEY=change-me-long-random-string
SIMULATOR_SESSION_COOKIE_NAME=simulator_session
SIMULATOR_SESSION_MAX_AGE_SECONDS=604800
SIMULATOR_SESSION_COOKIE_SECURE=true
SIMULATOR_SESSION_COOKIE_SAMESITE=lax

# --- API/web security ---
WEB_CORS_ORIGINS=https://simulator.example.com

# --- Runtime paths (inside container) ---
RUN_LOG_DIR=/workspace/simulate/runs/web-gui
SIM_GUI_PLANS_DIR=/workspace/simulate/runs/gui-plans

# --- Optional simulator credentials/cache ---
USER_LASTMILE_TOKEN=
USER_ID=
STORE_LASTMILE_TOKEN=
SIM_NEW_USER_PASSWORD=
STRIPE_SECRET_KEY=

# --- Optional external service URLs ---
LASTMILE_BASE_URL=https://lastmile.fainzy.tech
FAINZY_BASE_URL=https://fainzy.tech

# --- Optional simulator timing/runtime knobs ---
USER_DECISION_POLL_INTERVAL_SECONDS=5
USER_DECISION_POLL_MAX_ATTEMPTS=60
ORDER_PROCESSING_POLL_INTERVAL_SECONDS=5
ORDER_PROCESSING_POLL_MAX_ATTEMPTS=60
SIM_WEBSOCKET_CONNECT_GRACE_SECONDS=1
SIM_WEBSOCKET_DRAIN_SECONDS=3
SIM_WEBSOCKET_EVENT_TIMEOUT_SECONDS=20

# --- Optional local path overrides (normally not needed in prod) ---
SIMULATOR_WORKDIR=
SIMULATOR_PROJECT_DIR=
RUN_DB_PATH=

# ── User actor ──────────────────────────────────────────────────────────────
# Phone number of a registered, setup_complete=true user.
USER_PHONE_NUMBER=+819012345678
# Auto-managed by the simulator after the first successful OTP login.
# Reruns reuse this token until the backend rejects it, then refresh automatically.
USER_LASTMILE_TOKEN=
USER_ID=

# ── Store / Robot actor ──────────────────────────────────────────────────────
# Store login id. Used to fetch the real subentity profile.
STORE_ID=1
# If you already have a valid token, paste it here to skip the fetch
STORE_LASTMILE_TOKEN=

# ── Order seeding ────────────────────────────────────────────────────────────
# Numeric ID of the store (subentity) orders are placed at
SUBENTITY_ID=1
# Optional. If set, the fetched location search must return this id.
LOCATION_ID=
# ISO currency code matching the store's configured currency
STORE_CURRENCY=jpy

# ── Real delivery fixture lookup ─────────────────────────────────────────────
# Coordinates used to fetch real Fainzy delivery locations.
SIM_LAT=
SIM_LNG=
SIM_LOCATION_RADIUS=1

# ── Simulation mode ──────────────────────────────────────────────────────────
# load  = stochastic multi-actor traffic simulation
# trace = deterministic proof-oriented scenario execution
SIM_RUN_MODE=load
# Trace suite shortcut. "core" expands to completed,rejected,cancelled.
SIM_TRACE_SUITE=core
# Optional comma-separated override. Example: completed,cancelled,auto_cancel
SIM_TRACE_SCENARIOS=
# fast = short artificial delays for proof runs, realistic = human-like timings
SIM_TIMING_PROFILE=fast

# ── App probes / app-autopilot ──────────────────────────────────────────────
SIM_RUN_APP_PROBES=true
SIM_RUN_STORE_DASHBOARD_PROBES=true
SIM_RUN_POST_ORDER_ACTIONS=false
SIM_STRICT_PLAN=false
SIM_APP_AUTOPILOT=true
SIM_AUTO_SELECT_STORE=true
SIM_AUTO_SELECT_COUPON=true
SIM_AUTO_TOGGLE_STORE_STATUS=true
SIM_STORE_OPEN_STATUS=1
SIM_STORE_CLOSED_STATUS=3

# ── Payment simulation ───────────────────────────────────────────────────────
# Default full-flow mode. Requires a Stripe test secret key from the same
# account whose webhooks are connected to the backend.
SIM_PAYMENT_MODE=stripe
SIM_PAYMENT_CASE=paid_no_coupon
STRIPE_SECRET_KEY=
STRIPE_TEST_PAYMENT_METHOD=pm_card_visa
SIM_SAVE_CARD=false
# Free mode remains available for zero-total data-generation runs only.
SIM_FREE_ORDER_AMOUNT=0
SIM_COUPON_ID=

# ── Post-order review defaults ──────────────────────────────────────────────
SIM_REVIEW_RATING=4
SIM_REVIEW_COMMENT=Simulator review

# ── Auto-created menu defaults ───────────────────────────────────────────────
SIM_MENU_CATEGORY_NAME=Simulator
SIM_MENU_NAME=Simulator item
SIM_MENU_DESCRIPTION=Menu item created by simulator.
SIM_MENU_PRICE=100
SIM_MENU_INGREDIENTS=simulator ingredients
SIM_MENU_DISCOUNT=0
SIM_MENU_DISCOUNT_PRICE=0

# ── Base URLs ────────────────────────────────────────────────────────────────
LASTMILE_BASE_URL=https://lastmile.fainzy.tech
FAINZY_BASE_URL=https://fainzy.tech

# ── Simulation tuning ────────────────────────────────────────────────────────
# Number of concurrent users placing orders simultaneously
N_USERS=1
# Number of total orders in bounded mode
SIM_ORDERS=1
# Must be true for unbounded live endpoint traffic
SIM_CONTINUOUS=false
# Seconds between each user spawning a new order cycle
ORDER_INTERVAL_SECONDS=30
# Probability (0.0–1.0) that the store rejects an incoming order
REJECT_RATE=0.1

# ── Polling / websocket validation ───────────────────────────────────────────
USER_DECISION_POLL_INTERVAL_SECONDS=5
USER_DECISION_POLL_MAX_ATTEMPTS=60
ORDER_PROCESSING_POLL_INTERVAL_SECONDS=5
ORDER_PROCESSING_POLL_MAX_ATTEMPTS=60
SIM_WEBSOCKET_CONNECT_GRACE_SECONDS=1
SIM_WEBSOCKET_DRAIN_SECONDS=3
SIM_WEBSOCKET_EVENT_TIMEOUT_SECONDS=20
